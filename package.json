{
  "name": "finza",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:frontend": "bun run --filter frontend dev",
    "dev:backend": "bun run --filter backend dev",
    "db:migrate": "bun run --filter backend db:migrate",
    "db:create-admin": "bun run --filter backend db:create-admin"
  }
}
